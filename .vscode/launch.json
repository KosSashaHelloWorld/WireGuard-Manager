    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug Create Interface",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/wgm",
            "args": ["--command", "create", "--interface", "TestInterface", "-vd"],
            "stopAtEntry": true,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ]
        },
        {
            "name": "Debug Add Peer",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/wgm",
